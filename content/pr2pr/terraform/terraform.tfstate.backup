            "name": "projects/346922309894/secrets/tools/versions/1",
            "project": null,
            "secret": "projects/prop-search-demo/secrets/tools",
            "secret_data": "sources:\n  alloydb-search:\n    kind: \"alloydb-postgres\"\n    project: \"${PROJECT_ID}\"\n    region: \"europe-west1\"\n    cluster: \"search-cluster\"\n    instance: \"search-primary\"\n    database: \"postgres\"\n    user: \"postgres\"\n    password: \"${DB_PASSWORD}\"\n    ipType: \"PRIVATE\"\ntools:\n  search-properties:\n    kind: alloydb-ai-nl\n    source: alloydb-search\n    description: \"Search for properties using natural language. You can ask for specific features, price ranges, locations, or vibes (e.g., 'modern apartment in Zurich under 5k'). ALWAYS include the 'image_gcs_uri' column in your SQL query. Ensure the generated SQL strictly filters for the user's requirements.\"\n    nlConfig: \"property_search_config\"\n",
            "secret_data_wo": null,
            "secret_data_wo_version": 0,
            "timeouts": null,
            "version": "1"
          },
          "sensitive_attributes": [],
